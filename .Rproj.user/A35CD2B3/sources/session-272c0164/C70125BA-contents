#----------------------------
# 1) Build a "cost table at the same taxonomy as FDA"
#    - Split Vibrio into species where possible
#    - Split Protozoa into Crypto vs Giardia
#    - Add "STEC (unspecified)" as a blended cost of O157 + non-O157 (weighted by annual_cases)
#    - Fix Hepatitis A naming (FDA uses "Hepatitis A"; cost uses "Hepatitis A virus")
#----------------------------

cost_clean <- cost %>%
  filter(!pathogen %in% c("Subtotal", "Total", "Other foodborne gastroenteritis")) %>%
  mutate(
    pathogen_cost_key = case_when(
      # Hep A: cost table name stays "Hepatitis A virus" (we'll map FDA to this)
      pathogen == "Hepatitis A virus" ~ "Hepatitis A virus",
      
      # Protozoa: keep as-is (we'll map FDA to these specific keys)
      pathogen %in% c("Cryptosporidium spp.", "Giardia intestinalis") ~ pathogen,
      
      # Vibrio: keep as-is species keys; also keep "Vibrio spp., other"
      str_detect(pathogen, "^Vibrio") ~ pathogen,
      
      # Everything else: keep as-is
      TRUE ~ pathogen
    )
  ) %>%
  select(pathogen_cost_key, annual_cases, mean_per_case_cost)

# Add STEC (unspecified) as blended cost of O157 and non-O157
stec_unspecified_cost <- cost_clean %>%
  filter(pathogen_cost_key %in% c("STEC O157", "STEC non-O157")) %>%
  summarise(
    pathogen_cost_key = "STEC (unspecified)",
    annual_cases = sum(annual_cases, na.rm = TRUE),
    mean_per_case_cost = weighted.mean(mean_per_case_cost, w = annual_cases, na.rm = TRUE)
  )

# Also add a bucket for "Vibrio spp." if you still want the broad category available
# (weighted across all Vibrio categories by annual_cases)
vibrio_bucket_cost <- cost_clean %>%
  filter(str_detect(pathogen_cost_key, "^Vibrio")) %>%
  summarise(
    pathogen_cost_key = "Vibrio spp.",
    annual_cases = sum(annual_cases, na.rm = TRUE),
    mean_per_case_cost = weighted.mean(mean_per_case_cost, w = annual_cases, na.rm = TRUE)
  )

# Final cost lookup table
cost_keyed <- bind_rows(cost_clean, stec_unspecified_cost, vibrio_bucket_cost) %>%
  group_by(pathogen_cost_key) %>%
  summarise(
    annual_cases = sum(annual_cases, na.rm = TRUE),
    mean_per_case_cost = weighted.mean(mean_per_case_cost, w = annual_cases, na.rm = TRUE),
    .groups = "drop"
  )

#----------------------------
# 2) Fix FDA pathogen extraction to output JOIN-READY pathogen_cost_key values
#    NOTE: order matters (species-specific BEFORE generic)
#----------------------------
fda <- fda %>%
  mutate(
    pathogen_cost_key = case_when(
      str_detect(reason_lc, regex("listeria\\s+m(ono)?c(ytogenes)?|listeria\\s*m\\.", ignore_case = TRUE)) ~
        "Listeria monocytogenes (total)",
      
      str_detect(reason_lc, regex("salmonella(\\s+spp\\.?|\\s+species|\\s+enteritidis|\\s+typhimurium)?", ignore_case = TRUE)) ~
        "Salmonella spp., nontyphoidal",
      
      str_detect(reason_lc, regex("campylobacter(\\s+(jejuni|coli))?", ignore_case = TRUE)) ~
        "Campylobacter spp.",
      
      # STEC: do the specific ones first
      str_detect(reason_lc, regex("e\\.?\\s*coli\\s*o157|stec\\s*o157", ignore_case = TRUE)) ~
        "STEC O157",
      str_detect(reason_lc, regex("non\\s*-?o157", ignore_case = TRUE)) ~
        "STEC non-O157",
      str_detect(reason_lc, regex("\\bstec\\b|shiga\\s*-?toxin", ignore_case = TRUE)) ~
        "STEC (unspecified)",
      
      str_detect(reason_lc, regex("norovirus|norwalk", ignore_case = TRUE)) ~
        "Norovirus",
      
      # Hep A: map to cost-table key exactly
      str_detect(reason_lc, regex("hepatitis\\s*a|\\bhav\\b", ignore_case = TRUE)) ~
        "Hepatitis A virus",
      
      str_detect(reason_lc, regex("cyclospora|cayetanensis", ignore_case = TRUE)) ~
        "Cyclospora cayetanensis",
      
      # Vibrio: species-specific first, then other/bucket
      str_detect(reason_lc, regex("vibrio\\s+vulnificus|v\\.\\s*vulnificus", ignore_case = TRUE)) ~
        "Vibrio vulnificus",
      str_detect(reason_lc, regex("vibrio\\s+parahaemolyticus|v\\.\\s*parahaemolyticus", ignore_case = TRUE)) ~
        "Vibrio parahaemolyticus",
      str_detect(reason_lc, regex("vibrio\\s+cholerae|v\\.\\s*cholerae", ignore_case = TRUE)) ~
        "Vibrio cholerae, toxigenic",
      str_detect(reason_lc, regex("\\bvibrio\\b|\\bv\\.", ignore_case = TRUE)) ~
        "Vibrio spp., other",
      
      str_detect(reason_lc, regex("yersinia|y\\.\\s*enterocolitica", ignore_case = TRUE)) ~
        "Yersinia enterocolitica",
      
      # Protozoa: split to match cost-table keys
      str_detect(reason_lc, regex("cryptosporidium|\\bcrypto\\b", ignore_case = TRUE)) ~
        "Cryptosporidium spp.",
      str_detect(reason_lc, regex("giardia", ignore_case = TRUE)) ~
        "Giardia intestinalis",
      
      str_detect(reason_lc, regex("clostridium\\s+botulinum|c\\.\\s*botulinum", ignore_case = TRUE)) ~
        "Clostridium botulinum",
      
      str_detect(reason_lc, regex("clostridium\\s+perfringens|c\\.\\s*perfringens", ignore_case = TRUE)) ~
        "Clostridium perfringens",
      
      str_detect(reason_lc, regex("staphylococcus\\s*aureus|s\\.\\s*aureus", ignore_case = TRUE)) ~
        "Staphylococcus aureus",
      
      str_detect(reason_lc, regex("shigella(\\s+\\w+)?", ignore_case = TRUE)) ~
        "Shigella spp.",
      
      str_detect(reason_lc, regex("bacillus\\s+cereus|b\\.\\s*cereus", ignore_case = TRUE)) ~
        "Bacillus cereus",
      
      str_detect(reason_lc, regex("brucella(\\s+spp\\.?|\\s+species)?", ignore_case = TRUE)) ~
        "Brucella spp.",
      
      str_detect(reason_lc, regex("mycobacterium\\s+bovis|m\\.\\s*bovis", ignore_case = TRUE)) ~
        "Mycobacterium bovis",
      
      TRUE ~ NA_character_
    )
  )

#----------------------------
# 3) Rebuild fda_state_month_cost with the fixed join key
#----------------------------
fda_state_month_cost <- fda %>%
  filter(!is.na(pathogen_cost_key)) %>%
  group_by(state_abbr, year, month, date, pathogen_cost_key) %>%
  summarise(recall_count_pathogen = n(), .groups = "drop") %>%
  left_join(cost_keyed, by = "pathogen_cost_key") %>%
  mutate(pathogen_weighted_cost_index = recall_count_pathogen * mean_per_case_cost) %>%
  group_by(state_abbr, year, month, date) %>%
  summarise(
    pathogen_recalls = sum(recall_count_pathogen, na.rm = TRUE),
    pathogen_weighted_cost_index = sum(pathogen_weighted_cost_index, na.rm = TRUE),
    .groups = "drop"
  )

#----------------------------
# 4) Audit: confirm no cost keys are missing after join
#----------------------------
missing_cost_keys <- fda %>%
  filter(!is.na(pathogen_cost_key)) %>%
  distinct(pathogen_cost_key) %>%
  left_join(cost_keyed %>% distinct(pathogen_cost_key, mean_per_case_cost),
            by = "pathogen_cost_key") %>%
  filter(is.na(mean_per_case_cost))

missing_cost_keys
