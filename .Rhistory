suppressPackageStartupMessages({
library(readr)
library(dplyr)
library(tidyr)
library(stringr)
})
# Minimal state mapping: NOAA 3-digit -> state abbr/name via FIPS (01..)
state_fips_lookup <- tibble::tribble(
~state_fips, ~state_name,             ~state_abbr,
"01","Alabama","AL","02","Arizona","AZ","04","California","CA","06","Colorado","CO",
"08","Delaware","DE","09","Florida","FL","10","Georgia","GA","11","Idaho","ID",
"12","Illinois","IL","13","Indiana","IN","14","Iowa","IA","15","Kansas","KS",
"16","Kentucky","KY","17","Louisiana","LA","18","Maine","ME","19","Maryland","MD",
"20","Massachusetts","MA","21","Michigan","MI","22","Minnesota","MN","23","Mississippi","MS",
"24","Missouri","MO","25","Montana","MT","26","Nebraska","NE","27","Nevada","NV",
"28","New Hampshire","NH","29","New Jersey","NJ","30","New Mexico","NM","31","New York","NY",
"32","North Carolina","NC","33","North Dakota","ND","34","Ohio","OH","35","Oklahoma","OK",
"36","Oregon","OR","37","Pennsylvania","PA","38","Rhode Island","RI","39","South Carolina","SC",
"40","South Dakota","SD","41","Tennessee","TN","42","Texas","TX","43","Utah","UT",
"44","Vermont","VT","45","Virginia","VA","46","Washington","WA","47","West Virginia","WV",
"48","Wisconsin","WI","49","Wyoming","WY","50","Alaska","AK","51","Hawaii","HI",
"72","District of Columbia","DC"
)
read_climdiv_3_3_4 <- function(path, value_name) {
lines <- read_lines(path)
lines <- lines[nzchar(lines)]
toks <- str_split(str_trim(lines), "\\s+")
id <- vapply(toks, `[[`, character(1), 1)
# numeric values after id (may include extra columns beyond 12; we take first 12 months)
vals_list <- lapply(toks, function(x) as.numeric(x[-1]))
max_len <- max(vapply(vals_list, length, integer(1)))
mat <- do.call(rbind, lapply(vals_list, function(v) { length(v) <- max_len; v }))
if (ncol(mat) < 12) stop("Fewer than 12 numeric columns after ID.")
months12 <- mat[, 1:12, drop = FALSE]
colnames(months12) <- sprintf("m%02d", 1:12)
as_tibble(months12) %>%
mutate(id = str_pad(id, 10, side = "left", pad = "0")) %>%
mutate(
state_noaa3 = str_sub(id, 1, 3),                 # 001
division3   = str_sub(id, 4, 6),                 # 001, 002, ...
year        = as.integer(str_sub(id, 7, 10)),    # 1895
state_fips  = str_pad(as.character(as.integer(state_noaa3)), 2, pad = "0")
) %>%
pivot_longer(starts_with("m"), names_to = "month", values_to = value_name) %>%
mutate(
month = as.integer(str_remove(month, "^m")),
date = as.Date(sprintf("%04d-%02d-01", year, month))
) %>%
left_join(state_fips_lookup, by = "state_fips") %>%
filter(!is.na(state_name)) %>%
select(state_fips, state_abbr, state_name, division3, year, month, date, all_of(value_name)) %>%
arrange(state_fips, division3, date)
}
# --- your filenames
tmp_path  <- "climdiv-tmpcst-v1.0.0-20260205"   # temp (°F)
pcpn_path <- "climdiv-pcpnst-v1.0.0-20260205"   # precip (inches)
temp_df <- read_climdiv_3_3_4(tmp_path,  "temp_f")
pcpn_df <- read_climdiv_3_3_4(pcpn_path, "pcpn_in")
# --- your filenames
tmp_path  <- "climdiv-tmpcst-v1.0.0-20260205.txt"   # temp (°F)
pcpn_path <- "climdiv-pcpnst-v1.0.0-20260205.txt"   # precip (inches)
temp_df <- read_climdiv_3_3_4(tmp_path,  "temp_f")
pcpn_df <- read_climdiv_3_3_4(pcpn_path, "pcpn_in")
# Collapse divisions -> STATE-MONTH (what you want for easy joining/sharing)
temp_state_month <- temp_df %>%
group_by(state_fips, state_abbr, state_name, year, month, date) %>%
summarise(temp_f = mean(temp_f, na.rm = TRUE), .groups = "drop")
pcpn_state_month <- pcpn_df %>%
group_by(state_fips, state_abbr, state_name, year, month, date) %>%
summarise(pcpn_in = mean(pcpn_in, na.rm = TRUE), .groups = "drop")
# 1-to-1 join now
climate_state_month <- temp_state_month %>%
inner_join(pcpn_state_month, by = c("state_fips","state_abbr","state_name","year","month","date")) %>%
arrange(state_fips, date)
# Verify no duplicates
stopifnot(nrow(climate_state_month) ==
nrow(distinct(climate_state_month, state_fips, year, month)))
write_csv(climate_state_month, "climdiv_state_month_temp_pcpn.csv")
# quick peek
print(climate_state_month %>% slice_head(n = 12))
# check
str(climate_state_month)
################################################################################
climate_features <- climate_state_month %>%
group_by(state_fips) %>%
arrange(date) %>%
mutate(
# 1) lags
temp_f_lag1  = dplyr::lag(temp_f, 1),
temp_f_lag3  = dplyr::lag(temp_f, 3),
pcpn_in_lag1 = dplyr::lag(pcpn_in, 1),
pcpn_in_lag3 = dplyr::lag(pcpn_in, 3),
# 2) rolling means
temp_f_roll3 = slider::slide_dbl(temp_f, mean, .before = 2, .complete = TRUE),
temp_f_roll12 = slider::slide_dbl(temp_f, mean, .before = 11, .complete = TRUE),
pcpn_in_roll3 = slider::slide_dbl(pcpn_in, mean, .before = 2, .complete = TRUE),
pcpn_in_roll12 = slider::slide_dbl(pcpn_in, mean, .before = 11, .complete = TRUE),
# 3) extremes
temp_f_sd12 = slider::slide_dbl(temp_f, sd, .before = 11, .complete = TRUE),
pcpn_in_sd12 = slider::slide_dbl(pcpn_in, sd, .before = 11, .complete = TRUE),
# 4) month-of-year
month_sin = sin(2*pi*month/12),
month_cos = cos(2*pi*month/12)
) %>%
ungroup()
# anomalies vs each state's own 1991-2020 monthly climatology
climate_features <- climate_features %>%
group_by(state_fips, month) %>%
mutate(
temp_clim_1991_2020 = mean(temp_f[year >= 1991 & year <= 2020], na.rm = TRUE),
pcpn_clim_1991_2020 = mean(pcpn_in[year >= 1991 & year <= 2020], na.rm = TRUE),
temp_anom = temp_f - temp_clim_1991_2020,
pcpn_anom = pcpn_in - pcpn_clim_1991_2020
) %>%
ungroup()
str(climate_features)
